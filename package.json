{
  "name": "supertest-forge",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:debug": "jest --runInBand --detectOpenHandles",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci",
    "test:contracts": "PACT_ENABLED=true jest --runInBand \"contracts/**/*.test.ts\"",
    "test:real": "USE_REAL_API=true jest --runInBand --testPathPatterns=tests/.*\\.test\\.ts$",
    "test:notes:real": "USE_REAL_API=true jest --runInBand tests/notesFlow.test.ts",
    "test:place:real": "USE_REAL_API=true jest --runInBand tests/placeFlow.test.ts",
    "test:library:real": "USE_REAL_API=true jest --runInBand tests/libraryFlow.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "jest": "^30.3.0",
    "jest-html-reporters": "^3.1.7",
    "supertest": "^7.2.2",
    "ts-jest": "^29.3.4",
    "typescript": "^5.9.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.13.0",
    "@types/supertest": "^2.0.16"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@pact-foundation/pact": "^16.3.0",
    "ajv": "^8.18.0",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "faker": "^6.6.6",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  }
}
